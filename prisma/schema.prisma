generator client {
  provider = "prisma-client-js"
}


datasource db {
  provider = "postgresql"
}

model User {
  user_id      Int      @id @default(autoincrement())
  email        String   @unique
  passwordHash String
  username     String
  role         Role     @default(USER)
  createdAt    DateTime @default(now())

  projects     Project[]   @relation("UserProjects")
  messages     Message[]
}

model Project {
  id        Int      @id @default(autoincrement())
  name      String
  adminId   Int
  createdAt DateTime @default(now())

  admin     User     @relation("UserProjects", fields: [adminId], references: [user_id])
  messages  Message[]
}

model Message {
  id        Int      @id @default(autoincrement())
  content   String
  senderId  Int
  projectId Int
  createdAt DateTime @default(now())

  sender    User     @relation(fields: [senderId], references: [user_id])
  project   Project  @relation(fields: [projectId], references: [id])
}

enum Role {
  ADMIN
  USER
}
